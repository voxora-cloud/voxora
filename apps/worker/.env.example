# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email provider: mailhog | smtp | resend | sendgrid | ses | disabled
EMAIL_PROVIDER=mailhog

# SMTP (used when EMAIL_PROVIDER=smtp)
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=

# Resend (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# SendGrid (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# Amazon SES (used when EMAIL_PROVIDER=ses)
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=us-east-1

# Email sender identity
EMAIL_FROM_NAME=Voxora
EMAIL_FROM_ADDRESS=noreply@voxora.app

# Worker tuning
WORKER_CONCURRENCY=5
